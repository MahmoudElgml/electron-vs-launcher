    "directories": {
      "output": "dist"
    },
    "mac": {
      "identity": null
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "bootstrap": "^5.3.2",
    "electron-notification": "^1.0.0",
    "font-awesome": "^4.7.0"
  }
}
