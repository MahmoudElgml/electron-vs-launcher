{
  "name": "electron-vs-launcher",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/generate-app-icons.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "build": {
    "appId": "your.app.id",
